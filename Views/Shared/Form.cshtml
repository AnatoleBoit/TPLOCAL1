@model TPLOCAL1.Models.Form

@{
    Layout = "_Layout";
    ViewData["Title"] = "Formulaire";
    ViewData["Header"] = "Formulaire TP HN Avis";
    ViewData["Route1"] = "/Home";
    ViewData["Route1Text"] = "Accueil";
    ViewData["Route2"] = "/Home/Index/AvisListe";
    ViewData["Route2Text"] = "Avis Liste";
}

<div class="form-div">
    <form asp-controller="Home" asp-action="ValidationFormulaire" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <h4 class="form-title">Informations Personnelles</h4>
        <table class="form-table">
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Nom" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="Nom" class="form-control" required/><br />
                    <span asp-validation-for="Nom" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Prenom" class="control-label"></label>
                    </td>
                <td class="form-input">
                    <input asp-for="Prenom" class="form-control" required/><br />
                    <span asp-validation-for="Prenom" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Genre" class="control-label"></label>
                </td>
                <td class="form-input">
                    <select asp-for="Genre" class="form-control" required>
                        <option value="">Séléctionner un genre</option>
                        <option value="Homme">Homme</option>
                        <option value="Femme">Femme</option>
                        <option value="Autre">Autre</option>
                    </select><br />
                    <span asp-validation-for="Genre" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Adresse" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="Adresse" class="form-control" required /><br />
                    <span asp-validation-for="Adresse" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="CodePostal" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="CodePostal" class="form-control" required /><br />
                    <span asp-validation-for="CodePostal" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Ville" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="Ville" class="form-control" required /><br />
                    <span asp-validation-for="Ville" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="Email" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="Email" class="form-control" required /><br />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </td>
            </tr>
        </table>
        <h4 class="form-title">Informations sur la formation</h4>
        <table class="form-table">
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="DateDebutFormation" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="DateDebutFormation" class="form-control" required /><br />
                    <span asp-validation-for="DateDebutFormation" class="text-danger"></span>
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="FormationSuivie" class="control-label"></label>
                </td>
                <td class="form-input">
                    <select asp-for="FormationSuivie" class="form-control" required>
                        <option value="">Séléctionner une formation</option>
                        <option value="COBOL">COBOL</option>
                        <option value="C#">C#</option>
                        <option value="Double Compétence">Double Compétence</option>
                    </select><br />
                    <span asp-validation-for="FormationSuivie" class="text-danger"></span>
                </td>
            </tr>
        </table>
        <h4 class="form-title">Avis la formation</h4>
        <table class="form-table">
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="AvisFormCobol" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="AvisFormCobol" class="form-control" /><br />
                </td>
            </tr>
            <tr class="form-info">
                <td class="form-label">
                    <label asp-for="AvisFormCSharp" class="control-label"></label>
                </td>
                <td class="form-input">
                    <input asp-for="AvisFormCSharp" class="form-control" /><br />
                </td>
            </tr>
        </table>
        <div class=" = form-valide-div">
            <button type="submit" value="ValidationFormulaire" asp-action="ValidationFormulaire" class="form-valide">Valider</button>
        </div>
    </form>
</div>